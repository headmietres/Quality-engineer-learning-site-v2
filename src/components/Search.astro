---
// Search.astro — Pagefind 搜索组件

export interface Props {
  placeholder?: string;
}

const { placeholder = '搜索文章...' } = Astro.props;
const base = import.meta.env.BASE_URL;
const pagefindPath = base === '/' ? '/pagefind/pagefind.js' : base + '/pagefind/pagefind.js';
---

<div class="search-container relative" id="search-container" data-pagefind-src={pagefindPath}>
  <div class="relative">
    <svg class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>
    <input
      id="search-input"
      type="text"
      placeholder={placeholder}
      class="w-full pl-10 pr-4 py-2 text-sm border border-gray-300 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-[#e67e22] focus:border-transparent transition-shadow"
      autocomplete="off"
    />
  </div>
  <div id="search-results" class="hidden absolute top-full left-0 right-0 mt-1 bg-white border border-gray-200 rounded-lg shadow-xl max-h-96 overflow-y-auto z-50"></div>
</div>

<script>
(function(){
  var pagefind = null;
  var searchTimeout = null;

  var container = document.getElementById('search-container');
  var searchInput = document.getElementById('search-input');
  var searchResults = document.getElementById('search-results');
  var pagefindPath = '/pagefind/pagefind.js';

  if (container && container.dataset && container.dataset.pagefindSrc) {
    pagefindPath = container.dataset.pagefindSrc;
  }

  function loadPagefind(callback) {
    if (pagefind) {
      callback(pagefind);
      return;
    }
    if (window.pagefind) {
      pagefind = window.pagefind;
      callback(pagefind);
      return;
    }
    var script = document.createElement('script');
    script.src = pagefindPath;
    script.onload = function() {
      if (window.pagefind) {
        pagefind = window.pagefind;
      }
      callback(pagefind);
    };
    script.onerror = function() {
      console.warn('Pagefind not loaded');
      callback(null);
    };
    document.head.appendChild(script);
  }

  function performSearch(query) {
    if (!query || query.trim().length < 1) {
      searchResults.classList.add('hidden');
      searchResults.innerHTML = '';
      return;
    }

    loadPagefind(function(pf) {
      if (!pf) {
        searchResults.innerHTML = '<div class="p-4 text-sm text-gray-500">搜索索引未生成</div>';
        searchResults.classList.remove('hidden');
        return;
      }

      pf.search(query).then(function(result) {
        if (!result || !result.results || result.results.length === 0) {
          searchResults.innerHTML = '<div class="p-4 text-sm text-gray-500">未找到相关结果</div>';
          searchResults.classList.remove('hidden');
          return;
        }

        var items = result.results.slice(0, 8);
        var promises = items.map(function(r) { return r.data(); });

        Promise.all(promises).then(function(datas) {
          var html = '';
          for (var i = 0; i < datas.length; i++) {
            var data = datas[i];
            var meta = data.meta || {};
            var resultTitle = meta.title || data.title || '无标题';
            var resultExcerpt = data.excerpt || meta.description || '';
            var resultUrl = data.url;
            if (resultUrl.charAt(0) !== '/') {
              resultUrl = '/' + resultUrl;
            }
            html += '<a href="' + resultUrl + '" class="block px-4 py-3 hover:bg-orange-50 border-b border-gray-100 last:border-0 transition-colors">' +
              '<div class="text-sm font-medium text-[#1a3a5c]">' + escapeHtml(resultTitle) + '</div>' +
              '<div class="text-xs text-gray-500 mt-1 line-clamp-1">' + escapeHtml(resultExcerpt) + '</div>' +
              '<div class="text-xs text-[#e67e22] mt-1">' + escapeHtml(resultUrl) + '</div>' +
              '</a>';
          }
          searchResults.innerHTML = html;
          searchResults.classList.remove('hidden');
        });
      });
    });
  }

  function escapeHtml(str) {
    if (!str) return '';
    return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  if (searchInput && searchResults) {
    searchInput.addEventListener('input', function() {
      clearTimeout(searchTimeout);
      searchTimeout = setTimeout(function() {
        performSearch(searchInput.value);
      }, 300);
    });

    document.addEventListener('click', function(e) {
      var sc = document.getElementById('search-container');
      if (sc && !sc.contains(e.target)) {
        searchResults.classList.add('hidden');
      }
    });

    searchInput.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        searchResults.classList.add('hidden');
        searchInput.blur();
      }
    });
  }
})();
</script>
