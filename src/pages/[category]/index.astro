---
// [category]/index.astro — 分类列表页（动态路由）
// 用途：显示指定分类下的所有文章，按日期降序排列，支持分页

import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/Card.astro';
import { getCollection } from 'astro:content';
import { categoryMeta } from '../../content/config';
import { url } from '../../utils/index';

// Astro 分页：每页 6 篇文章
export async function getStaticPaths() {
  const categories = Object.keys(categoryMeta);
  const allPages: Array<{ params: { category: string }; props: { page: any } }> = [];

  for (const category of categories) {
    const articles = await getCollection(category, ({ data }) => data);
    // 按日期降序排序
    articles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

    const pageSize = 6;
    const totalPages = Math.ceil(articles.length / pageSize);

    for (let page = 1; page <= Math.max(totalPages, 1); page++) {
      const start = (page - 1) * pageSize;
      const end = start + pageSize;
      const pageArticles = articles.slice(start, end);

      const params = { category };
      if(p > 1){
        params.page = [String(p)]; // rest 参数要求数组
      }
      allPages.push({
        params,
        props: {
          page: {
            data: pageArticles,
            currentPage: p,
            totalPages: totalPages,
            category,
          },
        },
      });
    }
  }

  return allPages;
}

const { page } = Astro.props;
const { category } = Astro.params;
const meta = categoryMeta[category!];
const articles = page.data;
const currentPage = page.currentPage;
const totalPages = page.totalPages;
---

<BaseLayout title={meta?.name || category!} description={meta?.description} currentPath={`/${category}`}>
  <!-- 分类头部 -->
  <section class="bg-gradient-to-r from-[#1a3a5c] to-[#225577] text-white py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-blue-200 mb-4">
        <a href={url('/')} class="hover:text-white transition-colors">首页</a>
        <span class="mx-2">›</span>
        <span class="text-white">{meta?.name || category}</span>
      </nav>
      <h1 class="text-3xl font-bold mb-2">{meta?.name || category}</h1>
      <p class="text-blue-100">{meta?.description || ''}</p>
    </div>
  </section>

  <!-- 文章列表 -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    {
      articles.length > 0 ? (
        <div class="space-y-6">
          {
            articles.map((article) => (
              <a
                href={url(`/${category}/${article.slug}`)}
                class="block bg-white rounded-lg border border-gray-100 p-5 hover:border-[#e67e22] hover:shadow-sm transition-all"
              >
                <h2 class="text-lg font-semibold text-[#1a3a5c] hover:text-[#e67e22] transition-colors mb-2">
                  {article.data.title}
                </h2>
                <p class="text-sm text-gray-600 leading-relaxed mb-3">{article.data.description}</p>
                <div class="flex items-center gap-3 text-xs text-gray-400">
                  <span>{article.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                  <span>作者：{article.data.author}</span>
                  {
                    article.data.tags && article.data.tags.length > 0 && (
                      <div class="flex gap-1">
                        {article.data.tags.map((tag: string) => (
                          <span class="text-gray-500 bg-gray-100 px-1.5 py-0.5 rounded">{tag}</span>
                        ))}
                      </div>
                    )
                  }
                </div>
              </a>
            ))
          }
        </div>
      ) : (
        <div class="text-center py-16">
          <p class="text-gray-400 text-lg">该分类暂无文章</p>
          <a href={url('/')} class="inline-block mt-4 text-sm text-[#e67e22] hover:text-[#c96a1c]">返回首页</a>
        </div>
      )
    }

    <!-- 分页导航 -->
    {
      totalPages > 1 && (
        <nav class="flex justify-center items-center gap-4 mt-10">
          {
            currentPage > 1 && (
              <a
                href={currentPage === 2 ? url(`/${category}`) : url(`/${category}/${currentPage - 1}`)}
                class="px-4 py-2 text-sm text-[#1a3a5c] bg-white border border-gray-200 rounded-lg hover:border-[#e67e22] transition-colors"
              >
                ← 上一页
              </a>
            )
          }
          <span class="text-sm text-gray-500">
            第 {currentPage} / {totalPages} 页
          </span>
          {
            currentPage < totalPages && (
              <a
                href={url(`/${category}/${currentPage + 1}`)}
                class="px-4 py-2 text-sm text-[#1a3a5c] bg-white border border-gray-200 rounded-lg hover:border-[#e67e22] transition-colors"
              >
                下一页 →
              </a>
            )
          }
        </nav>
      )
    }
  </section>
</BaseLayout>
